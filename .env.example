# Runtime connection string. In production on Neon, use the pooled connection URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jajce

# Prisma CLI / migration connection string. In production on Neon, use the direct connection URL.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/jajce

# Required in production to sign admin session cookies.
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Used only to bootstrap the first admin account during seeding.
INITIAL_ADMIN_EMAIL=admin@jajce.mk
INITIAL_ADMIN_PASSWORD=change-me

# Optional. Defaults to Europe/Amsterdam if unset.
ADMIN_DASHBOARD_TIME_ZONE=Europe/Amsterdam

# Optional. Required only if you want MVP email notifications to send.
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
RESEND_API_BASE_URL=
